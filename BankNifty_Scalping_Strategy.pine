//@version=6
strategy("BankNifty 5-Min Scalping | EMA + RSI + Volume", 
     overlay=true, 
     default_qty_type=strategy.percent_of_equity, 
     default_qty_value=100, 
     initial_capital=100000, 
     commission_type=strategy.commission.percent, 
     commission_value=0.03, 
     slippage=2, 
     calc_on_every_tick=false,
     process_orders_on_close=false)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

// EMA Settings
emaFastLen   = input.int(9,   "Fast EMA Length",   minval=2, group="EMA Settings")
emaMidLen    = input.int(21,  "Mid EMA Length",    minval=2, group="EMA Settings")
emaSlowLen   = input.int(50,  "Slow EMA Length",   minval=2, group="EMA Settings")

// RSI Settings
rsiLen       = input.int(14,  "RSI Length",        minval=2, group="RSI Settings")
rsiOB        = input.int(70,  "RSI Overbought",   minval=50, maxval=95, group="RSI Settings")
rsiOS        = input.int(30,  "RSI Oversold",      minval=5,  maxval=50, group="RSI Settings")

// Volume Settings
volMultiplier = input.float(1.2, "Volume Multiplier (x SMA)", minval=0.5, step=0.1, group="Volume Settings")
volSmaLen     = input.int(20,    "Volume SMA Length",          minval=5,   group="Volume Settings")

// Risk Management
slPoints     = input.float(50,  "Stop Loss (Points)",        minval=5,  step=5,  group="Risk Management")
tpPoints     = input.float(100, "Take Profit (Points)",      minval=5,  step=5,  group="Risk Management")
useTrailStop = input.bool(true, "Use Trailing Stop",         group="Risk Management")
trailPoints  = input.float(30,  "Trailing Stop (Points)",    minval=5,  step=5,  group="Risk Management")
trailOffset  = input.float(15,  "Trailing Offset (Points)",  minval=5,  step=5,  group="Risk Management")

// Session Filter (IST — Indian Standard Time)
useSession   = input.bool(true, "Use Session Filter",        group="Session Filter")
sessionStart = input.int(915,   "Session Start (HHMM IST)",  minval=900, maxval=1530, group="Session Filter")
sessionEnd   = input.int(1500,  "Session End (HHMM IST)",    minval=900, maxval=1530, group="Session Filter")

// ─────────────────────────────────────────────────────────────────────────────
// CALCULATIONS
// ─────────────────────────────────────────────────────────────────────────────

// EMAs
emaFast = ta.ema(close, emaFastLen)
emaMid  = ta.ema(close, emaMidLen)
emaSlow = ta.ema(close, emaSlowLen)

// RSI
rsiVal = ta.rsi(close, rsiLen)

// Volume Confirmation
volSma      = ta.sma(volume, volSmaLen)
volConfirm  = volume > (volSma * volMultiplier)

// ─────────────────────────────────────────────────────────────────────────────
// SESSION FILTER
// ─────────────────────────────────────────────────────────────────────────────

currentHHMM = hour * 100 + minute
inSession   = useSession ? (currentHHMM >= sessionStart and currentHHMM <= sessionEnd) : true

// ─────────────────────────────────────────────────────────────────────────────
// ENTRY CONDITIONS
// ─────────────────────────────────────────────────────────────────────────────

// Bullish Setup:
// 1. Fast EMA crosses above Mid EMA (momentum shift)
// 2. Price is above Slow EMA (trend alignment)
// 3. RSI is between oversold and overbought (not exhausted)
// 4. Volume confirms the move
bullishEma    = ta.crossover(emaFast, emaMid)
bullishTrend  = close > emaSlow
bullishRsi    = rsiVal > rsiOS and rsiVal < rsiOB
longCondition = bullishEma and bullishTrend and bullishRsi and volConfirm and inSession

// Bearish Setup:
// 1. Fast EMA crosses below Mid EMA (momentum shift)
// 2. Price is below Slow EMA (trend alignment)
// 3. RSI is between oversold and overbought (not exhausted)
// 4. Volume confirms the move
bearishEma     = ta.crossunder(emaFast, emaMid)
bearishTrend   = close < emaSlow
bearishRsi     = rsiVal > rsiOS and rsiVal < rsiOB
shortCondition = bearishEma and bearishTrend and bearishRsi and volConfirm and inSession

// ─────────────────────────────────────────────────────────────────────────────
// STRATEGY EXECUTION
// ─────────────────────────────────────────────────────────────────────────────

// Long Entry
if longCondition and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    if useTrailStop
        strategy.exit("Long Exit", "Long", 
             stop=close - slPoints, 
             limit=close + tpPoints, 
             trail_points=trailPoints, 
             trail_offset=trailOffset)
    else
        strategy.exit("Long Exit", "Long", 
             stop=close - slPoints, 
             limit=close + tpPoints)

// Short Entry
if shortCondition and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    if useTrailStop
        strategy.exit("Short Exit", "Short", 
             stop=close + slPoints, 
             limit=close - tpPoints, 
             trail_points=trailPoints, 
             trail_offset=trailOffset)
    else
        strategy.exit("Short Exit", "Short", 
             stop=close + slPoints, 
             limit=close - tpPoints)

// Close all positions at end of session (intraday — no overnight risk)
if useSession and currentHHMM > sessionEnd and strategy.position_size != 0
    strategy.close_all(comment="Session End")

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS & VISUALS
// ─────────────────────────────────────────────────────────────────────────────

// EMA Plots
plot(emaFast, "EMA Fast (9)",  color=color.new(color.green, 0),  linewidth=1)
plot(emaMid,  "EMA Mid (21)",  color=color.new(color.orange, 0), linewidth=1)
plot(emaSlow, "EMA Slow (50)", color=color.new(color.red, 0),    linewidth=2)

// Background highlight when in active session
bgcolor(inSession ? color.new(color.blue, 95) : na, title="Session Window")

// Volume spike highlight
bgcolor(volConfirm ? color.new(color.yellow, 90) : na, title="Volume Spike")

// Signal markers
plotshape(longCondition,  title="Long Signal",  location=location.belowbar, 
     color=color.green, style=shape.triangleup,   size=size.small, text="BUY")
plotshape(shortCondition, title="Short Signal", location=location.abovebar, 
     color=color.red,   style=shape.triangledown, size=size.small, text="SELL")

// ─────────────────────────────────────────────────────────────────────────────
// INFO TABLE
// ─────────────────────────────────────────────────────────────────────────────

var table infoTable = table.new(position.top_right, 2, 5, 
     bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "Indicator",   text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "Value",       text_color=color.white, text_size=size.small)
    table.cell(infoTable, 0, 1, "RSI",         text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(rsiVal, "#.##"), 
         text_color=rsiVal > rsiOB ? color.red : rsiVal < rsiOS ? color.green : color.white, 
         text_size=size.small)
    table.cell(infoTable, 0, 2, "Vol Confirm",  text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, volConfirm ? "YES" : "NO", 
         text_color=volConfirm ? color.green : color.gray, text_size=size.small)
    table.cell(infoTable, 0, 3, "Trend",        text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, close > emaSlow ? "BULLISH" : "BEARISH", 
         text_color=close > emaSlow ? color.green : color.red, text_size=size.small)
    table.cell(infoTable, 0, 4, "In Session",   text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 4, inSession ? "YES" : "NO", 
         text_color=inSession ? color.green : color.gray, text_size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────

alertcondition(longCondition,  title="Long Entry Alert",  message="BankNifty LONG: EMA crossover + RSI + Volume confirmed")
alertcondition(shortCondition, title="Short Entry Alert", message="BankNifty SHORT: EMA crossunder + RSI + Volume confirmed")
